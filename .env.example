# ===== HIPNUS COSMÉTICOS — variáveis de ambiente =====
# Copie para .env e preencha. NUNCA versione o .env real.

# App
APP_ENV=local
DEBUG=true
SECRET_KEY=troque-esta-chave

# Banco — local (SQLite) | produção (MySQL Hostinger)
DATABASE_URL=sqlite:///./data/hipnus.db
# DATABASE_URL=mysql+pymysql://USUARIO:SENHA@HOST:3306/hipnus

# Asaas (API oficial) — sandbox por padrão
ASAAS_API_KEY=
ASAAS_BASE_URL=https://api-sandbox.asaas.com/v3
# ASAAS_BASE_URL=https://api.asaas.com/v3
ASAAS_WEBHOOK_TOKEN=
HIPNUS_PLATFORM_FEE_PERCENT=0

# SMTP Hostinger
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@hipnuscosmeticos.com.br

# Groq (Hipnus AI)
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile

# URLs
FRONTEND_BASE_URL=http://localhost:8501
BACKEND_BASE_URL=http://localhost:8000
